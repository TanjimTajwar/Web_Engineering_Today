# Copy to .env for local development. On Railway, set variables in the dashboard — do not commit real secrets.

# --- MySQL (Railway plugin injects MYSQL_URL, MYSQLHOST, MYSQLUSER, etc.) ---
# App on Railway should use MYSQL_URL (internal). For local Node connecting to Railway MySQL, use MYSQL_PUBLIC_URL from Railway’s MySQL service:
# MYSQL_PUBLIC_URL=mysql://...

# --- API server ---
# PORT=5000

# --- CORS: your Netlify frontend (https, no trailing slash). Multiple: url1,url2 ---
# CORS_ORIGIN=https://webprojectjobra.netlify.app

# --- JWT (set on Railway for production; changing it invalidates existing tokens) ---
# JWT_SECRET=your-long-random-string
