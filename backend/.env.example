# Copy to .env for local development. On Railway, set variables in the dashboard — do not commit real secrets.

# --- MySQL ---
# Railway (recommended): add DATABASE_URL = mysql://… from your MySQL service (Variables → Reference).
# Also supported: MYSQL_URL (internal), MYSQL_PUBLIC_URL (local machine → cloud MySQL).
# DATABASE_URL=mysql://user:pass@host:port/railway

# --- API server ---
# PORT=5000

# --- CORS: Netlify URL(s), https, no trailing slash. Server uses credentials: true (no wildcard origin). ---
# CORS_ORIGIN=https://webprojectjobra.netlify.app

# --- JWT (set on Railway for production; changing it invalidates existing tokens) ---
# JWT_SECRET=your-long-random-string
